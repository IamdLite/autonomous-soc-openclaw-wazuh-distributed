# =============================================================================
# Wazuh-OpenClaw-Autopilot  —  Environment Configuration
# Copy to .env and fill in your values before running deploy.sh
# =============================================================================

# ── Wazuh connection ──────────────────────────────────────────────────────────
# Your Wazuh manager IP or hostname (Tailscale IP if using mesh networking)
WAZUH_HOST=192.168.100.10
WAZUH_PORT=55000
WAZUH_USER=wazuh-wui
WAZUH_PASS=change-me-strong-password
WAZUH_VERIFY_SSL=false

# ── OpenSearch (bundled with Wazuh) ───────────────────────────────────────────
OPENSEARCH_HOST=opensearch-cluster-master
OPENSEARCH_PORT=9200
OPENSEARCH_USER=admin
OPENSEARCH_PASS=change-me-opensearch-password

# ── LLM provider (pick ONE) ───────────────────────────────────────────────────
# Option A — OpenRouter (recommended, access to Claude/GPT-4/Llama)
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_API_KEY=sk-or-your-openrouter-key
LLM_MODEL=anthropic/claude-3.5-sonnet

# Option B — OpenAI directly
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_API_KEY=sk-your-openai-key
# LLM_MODEL=gpt-4o

# Option C — Local Ollama (air-gapped, no external calls)
# LLM_BASE_URL=http://ollama-service:11434/v1
# LLM_API_KEY=ollama
# LLM_MODEL=llama3.1:70b

# ── Slack integration ─────────────────────────────────────────────────────────
SLACK_APP_TOKEN=xapp-1-your-app-token
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_CHANNEL_ID=C0XXXXXXXXX
# Slack user IDs allowed to approve response actions (comma-separated)
SLACK_APPROVERS=U0XXXXXXX,U0YYYYYYY

# ── MCP Server auth ───────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
MCP_AUTH_TOKEN=generate-with-openssl-rand-hex-32

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=soc-redis-secret-change-me

# ── NATS ─────────────────────────────────────────────────────────────────────
NATS_USER=soc-nats
NATS_PASSWORD=nats-secret-change-me

# ── Tailscale (optional — for cross-node Wazuh mesh) ─────────────────────────
TAILSCALE_AUTH_KEY=tskey-auth-your-key-here

# ── Feature flags ─────────────────────────────────────────────────────────────
# Enable automated response execution (requires human approval even when true)
RESPONDER_ENABLED=false
# Alert polling interval in ms
POLL_INTERVAL_MS=15000
# Max concurrent alert investigations
MAX_CONCURRENT_CASES=20
# Minimum Wazuh rule level to process (0-15)
MIN_ALERT_LEVEL=7
